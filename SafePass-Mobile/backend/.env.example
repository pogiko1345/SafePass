MONGODB_URI=
JWT_SECRET=
FRONTEND_URL=http://localhost:19006

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=SafePass <no-reply@example.com>

OCR_SPACE_API_KEY=
REQUIRE_OCR_ID_VALIDATION=false

# SMS gateway for phone login OTP.
# Use "iprogtech", "twilio", "semaphore", or "backend_log".
SMS_PROVIDER=iprogtech
SMS_ALLOW_BACKEND_LOG_FALLBACK=true

# iProgTech / IPROG SMS gateway for phone login OTP.
# Get this from your IPROG SMS account profile.
IPROGTECH_API_TOKEN=
IPROGTECH_BASE_URL=https://sms.iprogtech.com
IPROGTECH_SMS_PROVIDER=
IPROGTECH_OTP_MESSAGE=Your SafePass login OTP is {otp}. It expires in 5 minutes.
IPROGTECH_ALLOW_BACKEND_LOG_FALLBACK=true

# Twilio SMS gateway for phone login OTP.
# Use either TWILIO_MESSAGING_SERVICE_SID or TWILIO_PHONE_NUMBER.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_OTP_MESSAGE=Your SafePass login OTP is {otp}. It expires in 5 minutes.

# Semaphore SMS gateway for phone login OTP.
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=
SEMAPHORE_OTP_MESSAGE=Your SafePass login OTP is {otp}. It expires in 5 minutes.
SEMAPHORE_ALLOW_BACKEND_LOG_FALLBACK=true

ARDUINO_DEVICE_KEY=
