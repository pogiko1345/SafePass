{
  "buildCommand": "npm run build:web",
  "outputDirectory": "static",
  "devCommand": "npm run web",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!static/|favicon\\.ico|favicon-16\\.png|favicon-32\\.png|manifest\\.json|asyncStorageMock\\.js|pwa/).*)",
      "destination": "/index.html"
    }
  ]
}
