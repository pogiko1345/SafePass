{
  "expo": {
    "name": "Sapphire International Aviation Academy",
    "slug": "safepass-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoSapphire.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/LogoSapphire.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#041E42"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos of your ID for verification",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload your ID"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoSapphire.jpg",
        "backgroundColor": "#041E42"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon-school.png",
      "build": {
        "output": "static"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to upload your ID.",
          "cameraPermission": "The app needs access to your camera to take photos of your ID."
        }
      ]
    ]
  }
}
